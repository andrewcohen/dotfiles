{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {},
      "enabled": false
    }
  },
  "command": {
    "commit": {
      "template": "Using jujutsu, commit the current changeset in the conventional commit format, without a scope, using jj commit -m <message>",
      "description": "jj commit",
      "agent": "build"
    }
  }
}
