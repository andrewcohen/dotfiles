{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin-macchiato",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  },
  "command": {
    "commit": {
      "template": "Using jujutsu, commit the current changeset in the conventional commit format, without a scope, using jj commit -m <message>",
      "description": "jj commit",
      "agent": "build"
    }
  }
}
